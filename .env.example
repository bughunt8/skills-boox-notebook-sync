# ─────────────────────────────────────────────────────────────────────────────
# boox-reader skill — environment configuration template
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Then source it in your shell profile so it's available to the agent:
#   echo 'source ~/.hermes/skills/productivity/boox-reader/.env' >> ~/.bashrc
#   # or for zsh:
#   echo 'source ~/.hermes/skills/productivity/boox-reader/.env' >> ~/.zshrc
# ─────────────────────────────────────────────────────────────────────────────

# ── Required: path where your BOOX device syncs exported PDFs/PNGs ────────────
# Examples:
#   Google Drive:  ~/Google Drive/BOOX/Notes
#   Dropbox:       ~/Dropbox/BOOX/Notes
#   Syncthing:     ~/Sync/BOOX/Notes
#   Local USB:     /mnt/boox/Notes
export BOOX_SYNC_PATH="$HOME/Documents/BOOX/Notes"

# ── Required: Vision LLM provider to use for OCR ──────────────────────────────
# Options: openai | anthropic | google
export BOOX_OCR_PROVIDER="openai"

# ── API keys — set only the one matching your chosen provider ─────────────────

# OpenAI — used when BOOX_OCR_PROVIDER=openai (model: gpt-4o)
# Get your key: https://platform.openai.com/api-keys
export OPENAI_API_KEY="sk-..."

# Anthropic — used when BOOX_OCR_PROVIDER=anthropic (model: claude-3-5-sonnet)
# Get your key: https://console.anthropic.com/settings/keys
# export ANTHROPIC_API_KEY="sk-ant-..."

# Google AI Studio — used when BOOX_OCR_PROVIDER=google (model: gemini-1.5-flash)
# Get your key: https://aistudio.google.com/app/apikey
# export GOOGLE_API_KEY="AIza..."

# ── Optional: defaults for OCR behaviour ─────────────────────────────────────

# Primary handwriting language — ISO 639-1 code (e.g. en, zh, zh-TW, ja, fr)
export BOOX_READER_LANG_HINT="en"

# Output format: markdown | json | plain  (default: markdown)
# export BOOX_READER_OUTPUT_FORMAT="markdown"

# Seconds between page API calls for multi-page PDFs (default: 1.0)
# Increase if you hit 429 rate-limit errors.
# export BOOX_READER_PAGE_DELAY="1.0"
